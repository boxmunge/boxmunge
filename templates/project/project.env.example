# Environment variables for __PROJECT_NAME__
# Copy this to project.env and fill in real values.
# project.env is NEVER committed to git.

# Example variables (adjust for your project):
# NODE_ENV=production
# DATABASE_URL=postgresql://app:changeme@db:5432/appdb
# POSTGRES_USER=app
# POSTGRES_PASSWORD=changeme
# SECRET_KEY=generate-a-random-string-here
